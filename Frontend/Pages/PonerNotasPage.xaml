<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend.Pages.PonerNotasPage"
             Title="NewPage1">

    <Grid RowDefinitions="*, Auto" BackgroundColor="Black">
        <VerticalStackLayout>
            <Label 
        Text="Welcome to .NET MAUI!"
        VerticalOptions="Center" 
        HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- FOOTER: Fondo Negro, Línea Blanca y Texto Blanco -->
        <Grid Grid.Row="1" 
          ColumnDefinitions="*, *, *, *, *" 
          BackgroundColor="Black"
    
          HeightRequest="80" 
          Padding="0,0">

            <BoxView Grid.ColumnSpan="5"
             HeightRequest="1" 
             BackgroundColor="White" 
             HorizontalOptions="Fill" 
             VerticalOptions="Start" />

            <Label Grid.Column="0" Text="icon1" 
           HorizontalOptions="Center" VerticalOptions="Center" 
           FontSize="12" TextColor="White" FontFamily="Inter" />

            <Label Grid.Column="1" Text="icon2" 
           HorizontalOptions="Center" VerticalOptions="Center" 
           FontSize="12" TextColor="White" FontFamily="Inter" />

            <Label Grid.Column="2" Text="icon3" 
           HorizontalOptions="Center" VerticalOptions="Center" 
           FontSize="12" TextColor="White" FontFamily="Inter" />

            <Label Grid.Column="3" Text="icon4" 
           HorizontalOptions="Center" VerticalOptions="Center" 
           FontSize="12" TextColor="White" FontFamily="Inter" />

            <Label Grid.Column="4" Text="icon5" 
           HorizontalOptions="Center" VerticalOptions="Center" 
           FontSize="12" TextColor="White" FontFamily="Inter" />
        </Grid>
    </Grid>
        
</ContentPage>