<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend.Pages.ModificarNotasPage"
             Title="">

    <Grid RowDefinitions="*, Auto" BackgroundColor="Black">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout VerticalOptions="Start" Spacing="15" Padding="0,20,0,20">

                <!--usamos el horizontal layout en esta parte para que se pongan los elementos en el eje x-->
                <!--con fill el horizontaloptions hacemos que ocupe todo el eje x-->

                <Border x:Name="BordePrincipal" Margin="15,0"
                        StrokeShape="RoundRectangle 15"
                        StrokeThickness="0"
                        BackgroundColor="White">

                    <Grid Padding="15"
                          ColumnDefinitions="*"
                          HorizontalOptions="Fill">

                        <StackLayout Orientation="Horizontal" 
                                     HorizontalOptions="Center" 
                                     Spacing="10">

                            <Image x:Name="ImageIcono"
                                   Source="botoneditar.png"
                                   HeightRequest="26"
                                   WidthRequest="26"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>

                            <Label x:Name="Titulo"
                                   VerticalOptions="Center"
                                   Text="Modificar Notas" 
                                   FontSize="22"
                                   FontAttributes="Bold" 
                                   TextColor="#FF6600"/>
                        </StackLayout>
                    </Grid>
                </Border>

                <!--lo ponemos todo en un borde para poder ponerle un radius ya que no hay un solo label -->
                <Border BackgroundColor="White" 
                        StrokeShape="RoundRectangle 25" 
                        StrokeThickness="0"
                        Margin="15,0"
                        Padding="15"
                        HorizontalOptions="Fill">

                    <!--usamos grid + vertical layout para que todo que centrado correctamente...-->
                    <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="12">

                        <!-- Botón arriba del todo -->
                        <Button Grid.Row="0"
                        x:Name="BtnFlecha"
                        Text="Cambiar Linea ▼" 
                        TextColor="White"
                        BackgroundColor="transparent"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Clicked="OnFlechaClicked" />

                        <!-- Lista debajo del botón -->
                        <CollectionView Grid.Row="1"
                            x:Name="LineasView"
                            SelectionMode="Single"
                            IsVisible="false">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="5" BackgroundColor="{Binding Color}">
                                        <Label Text="{Binding Nombre}" 
                                           TextColor="White" 
                                           FontAttributes="Bold" 
                                           HorizontalTextAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Estación claramente debajo -->
                        <Label Grid.Row="2"
                       x:Name="LabelEstacion"
                       Text="Estacion: " 
                       FontSize="18"
                       FontAttributes="Bold" 
                       TextColor="#FF6600"
                       Margin="0,5,0,0"
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!--Lista de incidencias-->
                <CollectionView x:Name="lista_incidencias"
                                SelectionMode="Single"
                                IsVisible="false"
                                Margin="15,0"
                                SelectionChanged="OnIncidenciaSelected">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="Bordenotas"
                                    Padding="12"
                                    Stroke="{Binding ColorTexto}"
                                    StrokeThickness="3"
                                    StrokeShape="RoundRectangle 15">

                                <VerticalStackLayout Spacing="5">
                                    <Label x:Name="LabelTitulo"
                                           Text="{Binding titulo}"
                                           FontSize="20"
                                           TextColor="{Binding ColorTexto}"
                                           HorizontalTextAlignment="Center"/>

                                    <Label x:Name="LabelDescripción"
                                           Text="{Binding descripcion}"
                                           FontSize="14"
                                           TextColor="White"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--Editor de notas añadido-->
                <Border x:Name="ContenedorIncidencias" 
                        BackgroundColor="#212025" 
                        StrokeShape="RoundRectangle 15" 
                        StrokeThickness="0"
                        Margin="15,0"
                        Padding="15"
                        IsVisible="False" 
                        HorizontalOptions="Fill">

                    <VerticalStackLayout Spacing="12">

                        <!-- Título -->
                        <Border StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#4A4A4A"
                                Padding="10,5">

                            <Entry x:Name="TituloIncidencia"
                                   Placeholder="Titulo de la incidencia"
                                   PlaceholderColor="#808080"
                                   TextColor="White"
                                   BackgroundColor="Transparent" />
                        </Border>

                        <!-- Descripción -->
                        <Border StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#4A4A4A"
                                Padding="10,5">

                            <Editor x:Name="DescripcionIncidencia"
                                    Placeholder="Descripción"
                                    PlaceholderColor="#808080"
                                    TextColor="White"
                                    BackgroundColor="Transparent"
                                    HeightRequest="100"/>
                        </Border>

                        <!-- Botones de Acción -->
                        <Grid RowDefinitions="Auto, Auto" RowSpacing="10">

                            <Button x:Name="guardar"
                            Grid.Row="0"
                            Text="Guardar"
                            BackgroundColor="#FF6600"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="15"
                            Clicked="OnGuardarClicked" />

                            <Button Grid.Row="1"
                            Text="Eliminar"
                            BackgroundColor="Gray"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="15"
                            Clicked="OnEliminarClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- FOOTER: Fondo Negro, Línea Blanca y Texto Blanco -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*, *, *, *, *" 
              BackgroundColor="Black"
              HeightRequest="70">

            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="1" 
                     BackgroundColor="White" 
                     HorizontalOptions="Fill" 
                     VerticalOptions="Start" />

            <ImageButton Grid.Column="0" Source="circuloplus.png"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         HeightRequest="28" WidthRequest="28"
                         Clicked="OnPonerIncidenciaClicked" />

            <ImageButton Grid.Column="1" Source="libroabierto.png"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         HeightRequest="28" WidthRequest="28"
                         Clicked="OnLeerIncidenciaClicked" />

            <ImageButton Grid.Column="2" Source="menu.png"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         HeightRequest="28" WidthRequest="28"
                         Clicked="OnVolverAlMenuClicked" />

            <ImageButton Grid.Column="3" Source="punterosderuta.png"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         HeightRequest="28" WidthRequest="28"
                         Clicked="OnEnlaceClicked" />

            <ImageButton Grid.Column="4" Source="dataanalytics.png"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         HeightRequest="28" WidthRequest="28"/>
        </Grid>
    </Grid>

</ContentPage>