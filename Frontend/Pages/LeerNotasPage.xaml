<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend.Pages.LeerNotasPage"
             Title=""
             BackgroundColor="Black">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout  VerticalOptions="Start" Spacing="15" Padding="10,30,10,20">

                <!--usamos el horizontal layout en esta parte para que se pongan los elementos en el eje x-->
                <!--con fill el horizontaloptions hacemos que ocupe todo el eje x-->

                <Border x:Name="BordePrincipal"  Margin="10,0"
                        StrokeShape="RoundRectangle 15"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        >

                    <Grid  
                          Padding="15"
                          ColumnDefinitions="*" 
                          HorizontalOptions="Fill">

                        <StackLayout Orientation="Horizontal" 
                                     HorizontalOptions="Center" 
                                     Spacing="10">


                            <Image x:Name="ImageIcono"
                               Source="libroabierto.png"
                               HeightRequest="24"
                               WidthRequest="24"
                               VerticalOptions="Center"
                               HorizontalOptions="Center">
                            </Image>

                            <Label x:Name="Titulo" Text="Leer Notas" 
                                   FontSize="{OnIdiom Phone=22, Tablet=28}" 
                                   FontAttributes="Bold" 
                                   TextColor="#FF6600"
                                   VerticalOptions="Center" />
                        </StackLayout>
                    </Grid>
                </Border>


                <!--lo ponemos todo en un borde para poder ponerle un radius ya que no hay un solo label -->
                <Border BackgroundColor="White" 
                    StrokeShape="RoundRectangle 25" 
                    StrokeThickness="0"
                    Margin="10,0"
                    Padding="15"
                    HorizontalOptions="Fill">

                    <!--usamos grid + vertical layout para que todo que centrado correctamente...-->
                    <!--usamos grid + vertical layout para que todo que centrado correctamente...-->
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="10">

                        <!-- Botón cambiar línea -->
                        <Button Grid.Row="0"
                        x:Name="BtnFlecha"
                        Text="Cambiar Linea ▼" 
                        TextColor="#FFFFFF"
                        BackgroundColor="Transparent"
                        FontSize="16"
                        HeightRequest="45"
                        Clicked="OnFlechaClicked" />

                        <!-- Lista de líneas -->
                        <CollectionView Grid.Row="1"
                            x:Name="LineasView"
                            SelectionMode="Single"
                            IsVisible="false"
                            HeightRequest="150">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" Margin="3" BackgroundColor="{Binding Color}">
                                        <Label Text="{Binding Nombre}" 
                                       TextColor="White" 
                                       FontAttributes="Bold" 
                                       FontSize="14" 
                                       HorizontalTextAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Estación -->
                        <Label Grid.Row="2"
                           x:Name="LabelEstacion"
                           Text="Estacion: " 
                           FontSize="{OnIdiom Phone=18, Tablet=24}" 
                           FontAttributes="Bold" 
                           TextColor="#FF6600"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" 
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           MaxLines="2">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLabelEstacionTapped"/>
                            </Label.GestureRecognizers>

                        </Label>

                        <!-- Picker estaciones -->
                        <Picker Grid.Row="3"
                        x:Name="PickerEstaciones"
                        Title="Cambiar estación"
                        IsVisible="false"
                        SelectedIndexChanged="OnEstacionChanged"/>

                    </Grid>
                </Border>


                <!--Lista de incidencias-->
                <CollectionView x:Name="lista_incidencias"
                                SelectionMode="Single"
                                IsVisible="false"
                                Margin="10,0">

                    <!-- Esto añade la separación (espaciado) entre las notas -->
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <Border x:Name="Bordenotas"
                                    Padding="10"
                                    Stroke="{Binding ColorTexto}"
                                    StrokeThickness="3"
                                    StrokeShape="RoundRectangle 15">

                                <VerticalStackLayout Spacing="5">

                                    <Label x:Name="LabelTitulo"
                                           Text="{Binding titulo}"
                                           FontSize="20"
                                           TextColor="{Binding ColorTexto}"
                                           HorizontalTextAlignment="Center" />

                                    <Label x:Name="LabelDescripción"
                                           Text="{Binding descripcion}"
                                           FontSize="14"
                                           TextColor="White"
                                           HorizontalTextAlignment="Center" />

                                </VerticalStackLayout>
                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>



            </VerticalStackLayout>


        </ScrollView>




        <!--Iconos sacados de flaticon-->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*, *, *, *, *" 
              BackgroundColor="Black"
              HeightRequest="70">

            <BoxView Grid.ColumnSpan="5"
                     HeightRequest="1" 
                     BackgroundColor="White" 
                     HorizontalOptions="Fill" 
                     VerticalOptions="Start" />

            <!-- 1. Poner Notas -->
            <ImageButton Grid.Column="0" 
                         Source="circuloplus.png"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         HeightRequest="30"
                         WidthRequest="30"
                         Clicked="OnPonerIncidenciaClicked" />

            <!-- 2. Atras -->
            <ImageButton Grid.Column="1" 
                         Source="menu.png"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         HeightRequest="30"
                         WidthRequest="30"
                         Clicked="OnVolverAlMenuClicked" />

            <!-- 3. Modificar Notas -->
            <ImageButton Grid.Column="2" 
                         Source="botoneditar.png"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         HeightRequest="30"
                         WidthRequest="30"
                         Clicked="OnModificarIncidenciaClicked" />

            <!-- 4. Calcular Ruta -->
            <ImageButton Grid.Column="3" 
                         Source="punterosderuta.png"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         HeightRequest="30"
                         WidthRequest="30"
                         Clicked="OnEnlaceClicked" />

            <!-- 5. Estadísticas -->
            <ImageButton Grid.Column="4" 
                         Source="dataanalytics.png"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         HeightRequest="30"
                         WidthRequest="30"
                         Clicked="OnEstadisticasClicked"/>

        </Grid>
    </Grid>

</ContentPage>